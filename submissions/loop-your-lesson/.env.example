# Django
SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Docker: DATABASE_URL=postgres://dev:pass@localhost:5432/loop_dev
# Postgres.app: DATABASE_URL=postgres:///loop_dev
DATABASE_URL=postgres://dev:pass@localhost:5432/loop_dev

# Redis
REDIS_URL=redis://localhost:6381/0

# Temporal
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7235
TEMPORAL_NAMESPACE=default

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Agora (from https://console.agora.io -> Project -> Config)
# App ID: 32-char hex string, e.g. a1b2c3d4e5f6...
AGORA_APP_ID=
# App Certificate: 32-char hex string (enable in Project -> Config -> Security)
AGORA_APP_CERTIFICATE=
# Customer ID + Secret: RESTful API credentials (Console -> Developer Toolkit -> RESTful API)
# Used for Basic auth to ConvoAI endpoints
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=

# Avatar (Anam video avatar): https://app.anam.ai
AVATAR_API_KEY=
AVATAR_ID=
AVATAR_VENDOR=anam

# ElevenLabs (TTS for ConvoAI agent)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9

# Thymia (voice biomarkers): https://portal.thymia.ai
THYMIA_API_KEY=
THYMIA_BASE_URL=https://api.thymia.ai

# Classtime
CLASSTIME_ADMIN_TOKEN=
CLASSTIME_ORG_ID=
CLASSTIME_SCHOOL_ID=

# Ports
BACKEND_PORT=8006
FRONTEND_PORT=3006
